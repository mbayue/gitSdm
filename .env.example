# GitHub API (optional, increases rate limits for public repos)
GITHUB_TOKEN=

# AI provider: gemini | openai | anthropic | mock
AI_PROVIDER=mock

# AI API Key (mandatory)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model overrides (optional)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_VERSION=v1alpha
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Provider API base URL overrides (optional)
OPENAI_API_BASE=
ANTHROPIC_API_BASE=

# Embedding overrides (optional)
OPENAI_EMBEDDING_MODEL=openrouter/openai/text-embedding-3-large
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=3072

# Cache key hashing secret (optional, set a stable random value in production)
API_KEY_CACHE_HASH_SECRET=

# Production server binding (optional)
HOST=0.0.0.0
PORT=3000
