{
  "name": "gitsdm",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:server": "vite build --ssr server/prod-server.ts --outDir dist-server",
    "build:docker": "bun run build && bun run build:server",
    "start": "bun dist-server/prod-server.js",
    "preview": "vite preview",
    "test": "bun test --isolate",
    "test:watch": "bun test --isolate --watch",
    "test:coverage": "bun test --isolate --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "graphify:update": "graphify update . && python scripts/clean_graphify.py"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@google/genai": "^2.6.0",
    "@octokit/rest": "^21.1.1",
    "@tanstack/react-query": "^5.67.1",
    "@tanstack/react-virtual": "^3.13.2",
    "@xyflow/react": "^12.4.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "dagre": "^0.8.5",
    "framer-motion": "^12.4.10",
    "highlight.js": "^11.11.1",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "lru-cache": "^11.0.2",
    "lucide-react": "^1.18.0",
    "mermaid": "^11.15.0",
    "openai": "^4.86.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-2d": "^1.29.1",
    "react-router-dom": "^7.2.0",
    "recharts": "^2.15.1",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/d3-force": "^3.0.10",
    "@types/dagre": "^0.7.52",
    "@types/node": "^22.13.9",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vercel/node": "^5.1.8",
