    "bun-types": "^1.3.14",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^16.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.26.0",
    "vite": "^6.2.0"
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "@google/genai",
    "core-js",
    "esbuild",
    "protobufjs"
